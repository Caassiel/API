#include <iostream>
#include <random>
#include <cmath>
#include <unordered_set>
using namespace std;

static const int t = 50;
static const uint32_t N = (1 << 16) + 1;

wstring random_string() {
    static random_device rd;
    static mt19937 gen(rd());

    uniform_int_distribution<> len_dist(1, t);
    uniform_int_distribution<> char_dist(0x0400, 0x04FF);

    int len = len_dist(gen);

    wstring wstr;
    for (int i = 0; i < len; i++) {
        wstr.push_back((wchar_t)char_dist(gen));
    }

    return wstr;
}

uint32_t poly_hash(const wstring& s, uint32_t p) {
    uint32_t h = 0;

    for (wchar_t c : s)
        h = (h * p + (uint32_t)c) % N;

    return h;
}

class Bloom_Filter{

private:
    int s;
    vector<uint8_t> T;
    uint32_t p1, p2;


public:
    Bloom_Filter(int s) : s(s), T(N, 0) {
        random_device rd;
        mt19937 gen(rd());
        uniform_int_distribution<uint32_t> dist(31, 10000);

        p1 = dist(gen);
        p2 = dist(gen);
    }

    void Addition(const wstring& str){
        uint32_t h1 = poly_hash(str, p1);
        uint32_t h2 = poly_hash(str, p2);

        for (int i = 0; i < s; i++) {
            uint32_t idx = (h1 + i * h2) % N;
            T[idx] = 1;
        }
    }

    uint8_t DoesContain(const wstring& str){
        uint32_t h1 = poly_hash(str, p1);
        uint32_t h2 = poly_hash(str, p2);

        for (int i = 0; i < s; i++) {
            uint32_t idx = (h1 + i * h2) % N;
            if (!T[idx]) return 0;
        }
        return 1;
    }

    float Experiment(float a, int s) {
        unordered_set<wstring> inserted;

        int n = a * N;
        int M = 0;

        for (int i = 0; i < n; i++) {
            wstring str = random_string();
            inserted.insert(str);
            this->Addition(str);
        }

        while (true) {
            wstring str = random_string();
            if (inserted.count(str)) continue;
            if (this->DoesContain(str)) break;
            M++;
        }

        return 1.0f / (M + 1);
    }

};


int main() {

    int trials = 100;

    for (float a = 0.05; a <= 0.55; a += 0.05){
        float error = 0;
        float true_error = 0;

        for (int i = 0; i < trials; i++) {
            int s = floor(log(2)/a);
            Bloom_Filter b(s);
            error += b.Experiment(a, s);

            float base = 1 - exp(-a * s);
            true_error = pow(base, s);
        }

        cout << "Error for alpha = " << a << ":  " << error / trials
             << "\n" << "True error = " << true_error << "\n\n";
    }

    return 0;
}


    return 0;
}


